# Copy this file to .env.local for local development.
# Never commit or package .env.local.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key

# Configure these as Supabase Edge Function secrets, not Vite/browser variables.
# GMAIL_SMTP_HOST=smtp.gmail.com
# GMAIL_SMTP_PORT=587
# GMAIL_SMTP_SECURE=false
# GMAIL_SMTP_USER=notifications@gmail.com
# GMAIL_SMTP_APP_PASSWORD=your-16-character-app-password
# EMAIL_FROM_NAME=Site Connect
# EMAIL_FROM_ADDRESS=notifications@gmail.com
#
# For Gmail SSL use port 465 and GMAIL_SMTP_SECURE=true.
# CRON_SECRET=use-a-long-random-secret
